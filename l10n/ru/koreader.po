msgstr "Нет комментариев для отображения"

msgid "Could not find the server address"
msgstr "Не удалось найти адрес сервера"

msgid "This Z-library server is refusing automated access"
msgstr "Этот сервер Z-library блокирует автоматический доступ"

msgid "Credentials rejected or invalid response"
msgstr "Учётные данные отклонены или неверный ответ"

msgid "Request timed out - please check your connection and try again"
msgstr "Время ожидания истекло — проверьте подключение и повторите попытку"

msgid "Network request failed"
msgstr "Сетевой запрос не удался"

