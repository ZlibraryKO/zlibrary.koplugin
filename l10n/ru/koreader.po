msgid "Failed to fetch favorite-book IDs (no response body)."
msgstr "Не удалось получить ID избранных книг (нет тела ответа)."

msgid "Failed to parse favorite-book IDs."
msgstr "Не удалось разобрать ID избранных книг."

msgid "API returned an error for favorite-book IDs."
msgstr "API вернул ошибку для ID избранных книг."

msgid "Failed to fetch favorite book (no response body)."
msgstr "Не удалось добавить книгу в избранное (нет тела ответа)."

msgid "Failed to parse favorite book response."
msgstr "Не удалось разобрать ответ о добавлении в избранное."

msgid "API returned an error for favorite book."
msgstr "API вернул ошибку при добавлении в избранное."

msgid "Failed to fetch book comments (no response body)."
msgstr "Не удалось получить комментарии к книге (нет тела ответа)."

msgid "Failed to parse book comments response."
msgstr "Не удалось разобрать ответ с комментариями к книге."

msgid "API returned an error for book comments."
msgstr "API вернул ошибку для комментариев к книге."

