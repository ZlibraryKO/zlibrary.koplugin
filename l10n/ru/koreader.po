msgstr "Попробуйте другой сервер Z-library."

msgid "HTTP Error"
msgstr "Ошибка HTTP"

msgid "Unknown Status"
msgstr "Неизвестный статус"

msgid "The Z-library server address (URL) is not set. Please configure it in the Z-library plugin settings."
msgstr "Адрес сервера Z-library (URL) не задан. Пожалуйста, укажите его в настройках плагина Z-library."

msgid "Login failed: Empty response from server"
msgstr "Ошибка входа: пустой ответ от сервера"

msgid "Login failed: Invalid response format"
msgstr "Ошибка входа: неверный формат ответа"

msgid "Login failed"
msgstr "Ошибка входа"

msgid "Login failed: Invalid session data"
msgstr "Ошибка входа: неверные данные сессии"

msgid "No response received from server - please try again"
msgstr "Нет ответа от сервера — повторите попытку"

msgid "Invalid response format from server"
msgstr "Неверный формат ответа от сервера"

msgid "Search API error"
msgstr "Ошибка API поиска"

